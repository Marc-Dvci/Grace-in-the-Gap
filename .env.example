# Grace in the Gap requires live Gloo and YouVersion credentials.
# Both APIs are free for registered challenge participants.
# Copy this file to .env and fill in your keys. The CLI auto-loads .env.

# Gloo AI Studio  (https://studio.ai.gloo.com  >  API Credentials)
GLOO_CLIENT_ID=
GLOO_CLIENT_SECRET=

# YouVersion Platform  (https://developers.youversion.com  >  App Key)
YVP_APP_KEY=

# --- Optional overrides (sensible defaults shown) ---
GRACE_LOCALE=en-US
GRACE_BIBLE_VERSION_ID=3034
GRACE_TIME_ZONE=UTC
GRACE_TRADITION=ecumenical
GRACE_PREFERRED_TONE=balanced
GRACE_SHOW_SELECTION_REASON=true
GRACE_HISTORY_LIMIT=12
GRACE_MIN_WAIT_SECONDS=8
GRACE_COOLDOWN_MINUTES=10
GRACE_MAX_CARDS_PER_DAY=6
GRACE_CONTEXT_MODE=local-labels
GRACE_TELEMETRY_ENABLED=false

# Gloo endpoint: "tools" (default, schema-enforced tool calling) or "grounded"
# (after publishing a Grace-owned content library; then set GLOO_RAG_PUBLISHER).
GLOO_ENDPOINT_MODE=tools
GLOO_RAG_PUBLISHER=
GLOO_TRADITION=
GLOO_BASE_URL=https://platform.ai.gloo.com
GLOO_MODEL=gloo-openai-gpt-5-mini
YOUVERSION_BASE_URL=https://api.youversion.com

# Set to true only for a deterministic recording where every prompt shows a card.
GRACE_DEMO_ALWAYS=false
